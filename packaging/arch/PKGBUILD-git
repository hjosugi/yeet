pkgname=yeet-shelf-git
pkgver=0.2.0.r0.g0000000
pkgrel=1
pkgdesc='Native Yoink-style drag-and-drop shelf for Wayland and Windows (git)'
arch=('x86_64')
url='https://github.com/hjosugi/wayland-yeet'
license=('MIT')
depends=('gtk4' 'gtk4-layer-shell')
makedepends=('cargo' 'git')
provides=('yeet-shelf' 'yeet')
conflicts=('yeet-shelf' 'yeet')
source=('yeet::git+https://github.com/hjosugi/wayland-yeet.git')
sha256sums=('SKIP')

pkgver() {
  cd yeet
  git describe --long --tags --abbrev=7 | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd yeet
  cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
  cd yeet
  cargo build --release --locked
}

check() {
  cd yeet
  cargo test --locked
}

package() {
  cd yeet
  install -Dm755 target/release/yeet "$pkgdir/usr/bin/yeet"
  install -Dm644 packaging/linux/io.github.hjosugi.Yeet.desktop "$pkgdir/usr/share/applications/io.github.hjosugi.Yeet.desktop"
  install -Dm644 packaging/linux/io.github.hjosugi.Yeet.metainfo.xml "$pkgdir/usr/share/metainfo/io.github.hjosugi.Yeet.metainfo.xml"
  install -Dm644 assets/io.github.hjosugi.Yeet.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/io.github.hjosugi.Yeet.svg"
  install -Dm644 packaging/linux/yeet.1 "$pkgdir/usr/share/man/man1/yeet.1"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
